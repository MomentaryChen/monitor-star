{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "displayMode": "auto" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "percent"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Instance" }, "properties": [{ "id": "custom.width", "value": 180 }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "CPU %" }, { "id": "custom.cellOptions", "value": { "type": "color-background" } }] }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "cellHeight": "sm", "footer": { "countRows": false }, "showHeader": true },
      "title": "CPU Usage",
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "indexByName": {}, "renameByName": { "Value": "CPU %", "instance": "Instance" } } }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "process_cpu_usage{job=\"springboot-app\", instance=~\"$instance\"} * 100",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "displayMode": "auto" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "bytes"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Instance" }, "properties": [{ "id": "custom.width", "value": 180 }] },
          { "matcher": { "id": "byName", "options": "Heap Used" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background" } }] }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 6 },
      "id": 2,
      "options": { "cellHeight": "sm", "footer": { "countRows": false }, "showHeader": true },
      "title": "JVM Heap Used",
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "indexByName": {}, "renameByName": { "Value": "Heap Used", "instance": "Instance" } } }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_memory_used_bytes{job=\"springboot-app\", area=\"heap\", instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Active HTTP Sessions",
      "type": "stat",
      "targets": [
        {
          "expr": "tomcat_sessions_active_current_sessions{job=\"springboot-app\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}} - Sessions",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
      "id": 4,
      "title": "App Up (Total)",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(up{job=\"springboot-app\", instance=~\"$instance\"})",
          "legendFormat": "Up instances",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 18 },
      "id": 5,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"springboot-app\", instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}} | {{method}} {{uri}} [{{status}}]",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 18 },
      "id": 6,
      "title": "HTTP Response Time (p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"springboot-app\", instance=~\"$instance\"}[1m])) by (le, uri, instance))",
          "legendFormat": "{{instance}} | p99 {{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 30 },
      "id": 7,
      "title": "JVM Memory Usage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"springboot-app\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}} | {{area}} - {{id}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 30 },
      "id": 8,
      "title": "JVM Threads",
      "type": "timeseries",
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"springboot-app\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}} - Live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=\"springboot-app\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}} - Daemon",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["springboot", "java", "jvm"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "hide": 0,
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "query": "label_values(up{job=\"springboot-app\"}, instance)",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "allValue": "",
        "options": []
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Spring Boot Monitoring",
  "uid": "springboot-monitoring",
  "version": 2,
  "description": "上方 Instance 選單一節點可做單機排查；選 All 看全部實例。"
}
