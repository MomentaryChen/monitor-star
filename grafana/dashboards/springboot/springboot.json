{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 1 },
              { "color": "red", "value": 0.99 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "id": 4,
      "title": "App Up (All Selected Services)",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(up{job=~\"$service\", instance=~\"$instance\"})",
          "legendFormat": "Up instances",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "displayMode": "auto" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Service" }, "properties": [{ "id": "custom.width", "value": 200 }] },
          { "matcher": { "id": "byName", "options": "Up Instances" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background" } }] }
        ]
      },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 0 },
      "id": 9,
      "options": { "cellHeight": "sm", "footer": { "countRows": false }, "showHeader": true },
      "title": "Service Up by Service",
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": {
              "job": 0,
              "service": 1,
              "Service": 1,
              "instance": 2,
              "Instance": 2
            },
            "renameByName": {
              "job": "Service",
              "Value": "Up Instances"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "field": "Service",
                "desc": false
              }
            ]
          }
        }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (job) (up{job=~\"$service\"})",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "displayMode": "auto" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "percent"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Instance" }, "properties": [{ "id": "custom.width", "value": 180 }] },
          { "matcher": { "id": "byName", "options": "CPU %" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background" } }] }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 6 },
      "id": 1,
      "options": { "cellHeight": "sm", "footer": { "countRows": false }, "showHeader": true },
      "title": "CPU Usage by Instance",
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": {
              "job": 0,
              "service": 1,
              "Service": 1,
              "instance": 2,
              "Instance": 2
            },
            "renameByName": {
              "Value": "CPU %",
              "instance": "Instance"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "field": "job",
                "desc": false
              }
            ]
          }
        }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "process_cpu_usage{job=~\"$service\", instance=~\"$instance\"} * 100",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "displayMode": "auto" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "bytes"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Instance" }, "properties": [{ "id": "custom.width", "value": 180 }] },
          { "matcher": { "id": "byName", "options": "Heap Used" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background" } }] }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "id": 2,
      "options": { "cellHeight": "sm", "footer": { "countRows": false }, "showHeader": true },
      "title": "JVM Heap Used by Instance",
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": {
              "job": 0,
              "service": 1,
              "Service": 1,
              "instance": 2,
              "Instance": 2
            },
            "renameByName": {
              "Value": "Heap Used",
              "instance": "Instance"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "field": "job",
                "desc": false
              }
            ]
          }
        }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_memory_used_bytes{job=~\"$service\", area=\"heap\", instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 18 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Active HTTP Sessions (Selected Services)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(tomcat_sessions_active_current_sessions{job=~\"$service\", instance=~\"$instance\"})",
          "legendFormat": "Sessions",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 24 },
      "id": 5,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=~\"$service\", instance=~\"$instance\"}[1m])",
          "legendFormat": "{{job}} | {{instance}} | {{method}} {{uri}} [{{status}}]",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 24 },
      "id": 6,
      "title": "HTTP Response Time (p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=~\"$service\", instance=~\"$instance\"}[1m])) by (le, uri, instance, job))",
          "legendFormat": "{{job}} | {{instance}} | p99 {{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 36 },
      "id": 7,
      "title": "JVM Memory Usage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=~\"$service\", instance=~\"$instance\"}",
          "legendFormat": "{{job}} | {{instance}} | {{area}} - {{id}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 36 },
      "id": 8,
      "title": "JVM Threads",
      "type": "timeseries",
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=~\"$service\", instance=~\"$instance\"}",
          "legendFormat": "{{job}} | {{instance}} - Live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=~\"$service\", instance=~\"$instance\"}",
          "legendFormat": "{{job}} | {{instance}} - Daemon",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["springboot", "java", "jvm"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "hide": 0,
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "query": "label_values(up{job!=\"prometheus\"}, job)",
        "current": { "selected": true, "text": "All", "value": ".*" },
        "allValue": ".*",
        "options": []
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "hide": 0,
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "query": "label_values(up{job=~\"$service\"}, instance)",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "allValue": "",
        "options": []
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Spring Boot Monitoring — Multi-Service",
  "uid": "springboot-monitoring",
  "version": 3,
  "description": "依 Service / Instance 分開監控，多個 Spring Boot Service 與多實例場景適用。"
}
