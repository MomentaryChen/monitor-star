        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"] },
        "textMode": "value_and_name"
      },
      "title": "Total",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=\"springboot\", service=~\"$service\", instance_ip=~\"$instance_ip\"}[$__range]))",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
