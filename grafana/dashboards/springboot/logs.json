      "id": 7,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "description": "依 service 分組的每分鐘 log 速率，新 app 上線後自動出現",
      "title": "Log Rate by Service",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service) (rate({job=\"springboot\", service=~\"$service\", instance_ip=~\"$instance_ip\"}[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "id": 8,
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true,
        "displayMode": "lcd",
        "valueMode": "color"
      },
      "description": "時間範圍內 ERROR 數量最多的 Logger class (Top 10)，可快速定位問題模組",
      "title": "Top Error Loggers",
      "type": "bargauge",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(10, sum by (logger) (count_over_time({job=\"springboot\", service=~\"$service\", instance_ip=~\"$instance_ip\", level=\"ERROR\"}[$__range])))",
          "legendFormat": "{{logger}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "id": 9,
      "title": "Log Explorer",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 22, "w": 24, "x": 0, "y": 13 },
      "id": 10,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "description": "篩選條件說明：\n• Service — 多選下拉，新 app 上線後自動出現\n• Instance IP — 多選下拉，依選取 Service 而變動\n• Level — 多選下拉（ERROR / WARN / INFO / DEBUG）\n• Logger — 填入 class 名稱，如 HelloController\n• TraceId — 貼入 traceId 值，空白表示不篩\n• Keyword — 任意關鍵字全文搜尋",
      "title": "Spring Boot Logs",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"springboot\", service=~\"$service\", instance_ip=~\"$instance_ip\", level=~\"$level\"} |= \"$logger\" |= \"$search\" |= \"$traceId\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ],
