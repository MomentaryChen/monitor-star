<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

  <!-- springProperty 透過 Spring Environment 讀取，可正確取得 docker-compose 設定的環境變數 -->
  <springProperty name="LOG_PATH" source="LOG_PATH" defaultValue="/logs"/>
  <property name="LOG_PATTERN"
    value="[%-5level] %d{dd-MM-yyyy HH:mm:ss.SSS} [%thread] [traceId=%X{traceId:--},spanId=%X{spanId:--}] [ip=${INSTANCE_IP:-unknown}] %logger{0} - %msg%n"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
    </encoder>
  </appender>

  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/order-service.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/order-service.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
      <maxHistory>3</maxHistory>
    </rollingPolicy>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
    </encoder>
  </appender>

  <logger name="com.example.orderservice.monitor.OrderMonitorScheduler" level="DEBUG"/>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="FILE"/>
  </root>
</configuration>

